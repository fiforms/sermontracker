# Copy this file to .env and adjust values for your environment.

# Authentication mode.
#   dev   — no auth check; all requests run as the built-in dev user (id=1).
#           Use this for local development with `npm run dev`.
#   proxy — trust the X-Authentik-* headers forwarded by nginx+Authentik.
#           Required in production. Requests without X-Authentik-Email get 401.
AUTH_MODE=dev

# Port the Hono server listens on (default: 3000).
# PORT=3000

# Path to the SQLite database file (default: server/sermontracker.db in dev,
# /data/sermontracker.db in the Docker image).
# DATABASE_PATH=/data/sermontracker.db
