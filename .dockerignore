# Dependencies (reinstalled inside the build)
node_modules
**/node_modules

# Build output (rebuilt inside the build)
client/dist
server/dist

# Runtime database — never bake data into the image
server/*.db
server/*.db-shm
server/*.db-wal

# Dev/tooling
.git
.claude
*.md

# Local env overrides — production config comes from docker-compose environment:
.env
server/.env
server/.env.example
